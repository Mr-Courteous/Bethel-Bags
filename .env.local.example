# ─── Database ────────────────────────────────────────────────────────────────
# Get from: supabase.com, railway.app, or neon.tech (all have free tiers)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bethel_empire?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────── 
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set NEXTAUTH_URL to your live domain e.g. https://bethelempire.com

# ─── Paystack ────────────────────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
# Webhook URL to add in Paystack dashboard: https://yourdomain.com/api/webhooks/paystack

# ─── Resend (Email) ──────────────────────────────────────────────────────────
# Get from: resend.com (free: 3,000 emails/month)
# After signing up, verify your domain or use their sandbox for testing
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ─── Cloudinary (Image Uploads) ──────────────────────────────────────────────
# Get from: cloudinary.com (free: 25GB storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Site Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://bethelempire.com"

# ─── Admin Notifications ─────────────────────────────────────────────────────
# Email address that receives contact form messages
ADMIN_EMAIL="admin@bethelempire.com"
